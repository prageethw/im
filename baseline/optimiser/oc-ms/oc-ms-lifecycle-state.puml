@startuml oc-ms-lifecycle-state
' OC MS runtime Optimisation lifecycle state model
' State-only view.

hide empty description
left to right direction
skinparam shadowing false
skinparam state {
  BackgroundColor White
  BorderColor Black
  FontColor Black
}

title OC MS - Runtime Optimisation lifecycle states

[*] --> ACKNOWLEDGED : create NEW
FAILED --> ACKNOWLEDGED : create RETRIAL

ACKNOWLEDGED --> QUEUED
QUEUED --> PROCESSING

PROCESSING --> COMPLETED
PROCESSING --> INFEASIBLE
PROCESSING --> FAILED

ACKNOWLEDGED --> CANCELLING
QUEUED --> CANCELLING
PROCESSING --> CANCELLING

CANCELLING --> CANCELLED
CANCELLING --> CANCELLATIONFAILED

CANCELLATIONFAILED --> COMPLETED
CANCELLATIONFAILED --> INFEASIBLE
CANCELLATIONFAILED --> FAILED

COMPLETED --> [*]
INFEASIBLE --> [*]
FAILED --> [*]
CANCELLED --> [*]

ACKNOWLEDGED : Accepted and persisted
QUEUED : Waiting for worker
PROCESSING : Worker processing
COMPLETED : Terminal success
INFEASIBLE : Terminal infeasible outcome
FAILED : Terminal failure
CANCELLING : Cancellation in progress
CANCELLED : Terminal cancellation
CANCELLATIONFAILED : Non-terminal cancellation failure

@enduml
