@startuml
title Intent Intelligence MS (II MS) - Semantic Interpretation Sequence Flow

!theme plain
skinparam sequenceMessageAlign center
skinparam backgroundColor #FFFFFF
skinparam participantBackgroundColor #dae8fc
skinparam participantBorderColor #6c8ebf
skinparam sequenceArrowColor #333333
skinparam noteBorderColor #d6b656
skinparam noteBackgroundColor #fff2cc
skinparam dividerBackgroundColor #f0f0f0
skinparam sequenceGroupBackgroundColor #f9f9f9

participant "Kafka\n(internal event backbone)" as KAFKA
participant "Intent Intelligence MS\n(II MS)" as IIMS
participant "Knowledge Plane\n(KP)" as KP
participant "Other T7 services and governed sources\n(optional pre-resolution validation)" as AUTH
participant "Optimiser Platform\n(POST /optimisation)" as OPT
participant "Intent Callback MS\n(ICB MS)" as ICB
database "II MS Store\n(semantic state + outbox)" as STORE
participant "Outbox Relay\n(background worker)" as RELAY
participant "IC MS" as ICMS
participant "Optional observers\n(audit, replay, future consumers)" as OBS

== 1. Consume IntentValidatedEvent ==

IIMS -> KAFKA : consume event
IIMS -> STORE : check deduplication record\n(cloudEventsId + intentId)

alt already processed (duplicate)
  STORE --> IIMS : duplicate found
  IIMS -> KAFKA : ack (idempotent - no reprocessing)
else not yet processed
  STORE --> IIMS : no duplicate - proceed

  == 2. Check Admission Context and Parse Expression Context ==

  IIMS -> IIMS : confirm body.intentSpecification.id is present\n(selected active spec from IC MS)
  IIMS -> IIMS : confirm body.expression.iri is present\n(admitted semantic expression contract)
  note over IIMS
    II MS treats intentSpecification.id and expression.iri
    as carried-forward admission facts from IC MS.
    It does not re-resolve the governing specification by IRI alone.
  end note

  IIMS -> IIMS : parse body.expression.context.targets\n(latency, availability, jitter, packet loss, ...)
  IIMS -> IIMS : parse body.expression.context.constraints\n(location, service class, priority,\nredundancy, time window, ...)
  IIMS -> IIMS : parse body.expression.context.preferences\n(soft selection guidance)

  == 3. Knowledge Plane and Required Pre-Resolution Validation ==

  IIMS -> KP : resolve location context
  KP --> IIMS : location scope + region metadata
  IIMS -> KP : resolve service type + service class
  KP --> IIMS : service type definition + class capabilities
  IIMS -> KP : resolve capability context\n(what the network can currently deliver)
  KP --> IIMS : capability profile { latency, availability, jitter, packet loss }
  IIMS -> KP : resolve policy context\n(scope filters, constraint promotion rules)
  KP --> IIMS : applicable policies + constraint promotion set
  IIMS -> KP : resolve resource context\n(candidate resource set pre-filter)
  KP --> IIMS : raw candidate resource set
  opt use-case requires additional facts
    IIMS -> AUTH : resolve additional domain facts\n(inventory, policy, topology, capacity, catalogue, fulfilment, etc.)
    AUTH --> IIMS : validated facts and decision inputs
  end

  == 4. Hard Constraint Validation ==

  note over IIMS
    Hard constraints must be satisfiable within
    resolved capability context.
  end note

  IIMS -> IIMS : validate location constraint\nagainst resolved location scope
  IIMS -> IIMS : validate service class constraint\nagainst capability profile
  IIMS -> IIMS : validate priority constraint
  IIMS -> IIMS : validate redundancy constraint
  IIMS -> IIMS : validate time window constraint

  alt any hard constraint unsatisfiable
    IIMS -> IIMS : semantic rejection - hard constraint failure
    group Atomic DB transaction
      IIMS -> STORE : persist semantic decision trail\n{ reason: CONSTRAINT_VIOLATION, detail }
      IIMS -> STORE : write IntentRejectedEvent to outbox\n{ intentId, rejectionClass: CONSTRAINT, reason }
    end
    RELAY -> STORE : poll -> IntentRejectedEvent
    RELAY -> KAFKA : publish IntentRejectedEvent
    ICMS -> KAFKA : consume event
  else all hard constraints satisfiable

    == 5. Measurable Target Validation ==

    note over IIMS
      Targets are validated against known
      capability context from KP and any
      required pre-resolution validation sources.
    end note

    IIMS -> IIMS : validate latency target\nvs capability profile
    IIMS -> IIMS : validate availability target\nvs capability profile
    IIMS -> IIMS : validate jitter target\nvs capability profile
    IIMS -> IIMS : validate packet loss target\nvs capability profile

    alt any measurable target outside capability context
      IIMS -> IIMS : semantic rejection - capability not met
      group Atomic DB transaction
        IIMS -> STORE : persist semantic decision trail\n{ reason: CAPABILITY_EXCEEDED, detail }
        IIMS -> STORE : write IntentRejectedEvent to outbox\n{ intentId, rejectionClass: CAPABILITY, reason }
      end
      RELAY -> STORE : poll -> IntentRejectedEvent
      RELAY -> KAFKA : publish IntentRejectedEvent
      ICMS -> KAFKA : consume event
    else all targets within capability context

      == 6. Preference Handling ==

      note over IIMS
        Preferences are soft guidance unless policy
        explicitly promotes them to hard constraints.
      end note

      IIMS -> IIMS : evaluate preferences against policy promotion rules

      alt policy promotes preference to hard constraint
        IIMS -> IIMS : re-validate as hard constraint\n(steps 4-5 apply)
      else preference remains soft
        IIMS -> IIMS : preserve preference as soft selection guidance\nfor candidate ranking
      end

      == 7. Canonicalisation ==

      IIMS -> IIMS : normalise canonical semantic buckets\n- targets -> normalised measurement set\n- constraints -> validated hard set\n- preferences -> ranked soft guidance set

      == 8. Candidate Discovery ==

      IIMS -> IIMS : apply scope + policy filters\nto raw candidate resource set from KP
      IIMS -> IIMS : resolve complete valid candidate resource set\nfor current semantic context

      alt no valid candidates found after filtering
        IIMS -> IIMS : semantic rejection - no candidates
        group Atomic DB transaction
          IIMS -> STORE : persist semantic decision trail\n{ reason: NO_CANDIDATES, detail }
          IIMS -> STORE : write IntentRejectedEvent to outbox\n{ intentId, rejectionClass: POLICY, reason }
        end
        RELAY -> STORE : poll -> IntentRejectedEvent
        RELAY -> KAFKA : publish IntentRejectedEvent
        ICMS -> KAFKA : consume event
      else valid candidates resolved

        == 9. Record Semantic Decision + Optional Resolution Observability Event ==

        group Atomic DB transaction
          IIMS -> STORE : persist semantic decision trail\n{ candidateSet, canonicalTargets,\n canonicalConstraints, canonicalPreferences }
          IIMS -> STORE : write IntentResolvedEvent to outbox\n{ intentId, candidateSet, canonicalContext }
          IIMS -> STORE : write deduplication record\n(cloudEventsId + intentId -> PROCESSED)
        end

        == 10. Outbox Relay - Publish to Kafka ==

        RELAY -> STORE : poll PENDING outbox rows
        STORE --> RELAY : [IntentResolvedEvent]
        RELAY -> KAFKA : publish IntentResolvedEvent
        STORE <- RELAY : mark row DELIVERED

        == 11. Optimisation-Backed Selection and Service-Ready Preparation ==

        note over IIMS,OPT
          IntentResolvedEvent is optional and is not the
          optimiser trigger. When optimisation-backed
          selection is required, II MS submits the resolved
          candidate context directly to the Optimiser platform
          using POST /optimisation through its API outbox.
          II MS registers or supplies the ICB callback URL.
          Optimiser owns selection logic and returns the
          governed selected configuration as a request to ICB.
          ICB relays OptimisationStatusChangeEvent to Kafka.
        end note

        IIMS -> OPT : POST /optimisation\n{ body.expression.context, candidate resources,\n targets, constraints, preferences, correlation,\n ICB callback URL }
        OPT -> ICB : POST /intent-callback/v1/submissions\nOptimisationStatusChangeEventRequest { selectedConfiguration }
        ICB -> KAFKA : publish OptimisationStatusChangeEvent
with CloudEvents headers
{ ce-type, ce-source, ce-subject }
        IIMS -> KAFKA : consume OptimisationStatusChangeEvent
with CloudEvents headers
        IIMS -> IIMS : correlate + persist optimiser outcome idempotently\nthen package selected configuration into IntentNetworkReadyEvent

        group Atomic DB transaction
          IIMS -> STORE : update semantic decision trail\n{ optimisationId, selectedConfiguration, readyState }
          IIMS -> STORE : write IntentNetworkReadyEvent to outbox\n{ intentId, expression.context, serviceConfiguration, references }
        end

        RELAY -> STORE : poll -> IntentNetworkReadyEvent
        RELAY -> KAFKA : publish IntentNetworkReadyEvent
        STORE <- RELAY : mark row DELIVERED

        == 12. Downstream Consumers Continue Workflow ==

        ICMS -> KAFKA : consume IntentNetworkReadyEvent
(optional progress projection)
        OBS -> KAFKA : optionally observe workflow events
        note over IIMS,KAFKA
          IntentResolvedEvent is retained as an optional
          semantic milestone for audit, observability, replay,
          and future consumers. It is not required for the
          happy-path optimisation invocation.
        end note
      end
    end
  end
end

@enduml
