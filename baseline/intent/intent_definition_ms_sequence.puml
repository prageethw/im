@startuml Intent Definition MS - Sequence Flow
!theme plain
skinparam sequenceMessageAlign center
skinparam backgroundColor #FFFFFF
skinparam participantBackgroundColor #dae8fc
skinparam participantBorderColor #6c8ebf
skinparam sequenceArrowColor #333333
skinparam noteBorderColor #d6b656
skinparam noteBackgroundColor #fff2cc
skinparam dividerBackgroundColor #f0f0f0
skinparam sequenceGroupBackgroundColor #f9f9f9

title Intent Definition MS (ID MS) — Primary Process Sequence Flows

actor "External Client\n/ OEX / Auth Platform" as Client
participant "NGW / API Gateway" as GW
participant "Intent Definition MS\n(ID MS)" as IDMS
collections "IntentSpec\nCatalogue" as CAT
database "Outbox Table\n(DB)" as OUTBOX
database "Subscription\nRegistry (DB)" as SUBREG
participant "Outbox Dispatcher\n(background worker)" as DISPATCHER
actor "External Subscriber\nSystem" as SUB

== 7a. Register External Event Subscription ==
note over Client, SUBREG : External Subscriber registers its HTTPS callback URL with the hub
Client -> GW : POST /intentManagement/v5/hub\n{ callback: "https://subscriber.example/notify", query: "eventType=..." }
GW -> IDMS : forward request
IDMS -> SUBREG : persist subscription record\n{ id, callbackUrl, eventTypeFilter }
SUBREG --> IDMS : 201 { subscriptionId }
IDMS --> GW : 201 Created { subscriptionId, callbackUrl }
GW --> Client : 201 Created { subscription }

== 1. Create New Draft IntentSpecification ==
Client -> GW : POST /intentManagement/v5/intentSpecification\n{ name, version, familyId, lifecycleStatus: "Draft", ... }
GW -> IDMS : forward request
group Atomic DB transaction
    IDMS -> CAT : persist new draft IntentSpecification
    IDMS -> OUTBOX : write IntentSpecificationCreateEvent row\n{ eventType, resourceId, payload, status: PENDING }
end
IDMS --> GW : 201 Created { intentSpecification }
GW --> Client : 201 Created { intentSpecification }
|||
DISPATCHER -> OUTBOX : poll for PENDING event rows
OUTBOX --> DISPATCHER : [IntentSpecificationCreateEvent]
DISPATCHER -> SUBREG : lookup subscriptions matching eventType
SUBREG --> DISPATCHER : [{ subscriptionId, callbackUrl }]
loop for each matched subscription
    DISPATCHER -> SUB : HTTPS POST {callbackUrl}\n{ event: IntentSpecificationCreateEvent, resourceId, timestamp, ... }
    alt HTTP 2xx
        SUB --> DISPATCHER : 200 OK
        DISPATCHER -> OUTBOX : mark event row DELIVERED
    else HTTP error / timeout
        SUB --> DISPATCHER : 4xx / 5xx / timeout
        DISPATCHER -> OUTBOX : increment retry count\n(exponential back-off, dead-letter after max retries)
    end
end

== 2. Retrieve / List IntentSpecifications ==
Client -> GW : GET /intentManagement/v5/intentSpecification  or  GET /.../{id}
GW -> IDMS : forward request
IDMS -> CAT : query catalogue (discovery / runtime validation)
CAT --> IDMS : [IntentSpecification] or single record
IDMS --> GW : 200 OK { result }
GW --> Client : 200 OK { result }
note over Client, CAT : Read-only — no outbox event written

== 3a. Full-Replacement Update (preferred — PUT) ==
note over Client, IDMS : Caller submits complete resource representation
Client -> GW : PUT /intentManagement/v5/intentSpecification/{id}\n{ full resource body }
GW -> IDMS : forward request
group Atomic DB transaction
    IDMS -> CAT : replace draft IntentSpecification
    IDMS -> OUTBOX : write IntentSpecificationAttributeValueChangeEvent row
end
IDMS --> GW : 200 OK { intentSpecification }
GW --> Client : 200 OK { intentSpecification }
|||
DISPATCHER -> OUTBOX : poll → PENDING AttributeValueChangeEvent
OUTBOX --> DISPATCHER : [IntentSpecificationAttributeValueChangeEvent]
DISPATCHER -> SUBREG : lookup matching subscriptions
SUBREG --> DISPATCHER : [{ callbackUrl }]
DISPATCHER -> SUB : HTTPS POST {callbackUrl}\n{ event: IntentSpecificationAttributeValueChangeEvent }
SUB --> DISPATCHER : 200 OK
DISPATCHER -> OUTBOX : mark DELIVERED

== 3b. Partial Update (TMF-strict PATCH) ==
note over Client, IDMS : Tightly controlled fields only; spec must be in Draft state
Client -> GW : PATCH /intentManagement/v5/intentSpecification/{id}\n{ partial fields }
GW -> IDMS : forward request
group Atomic DB transaction
    IDMS -> CAT : apply partial update to draft IntentSpecification
    IDMS -> OUTBOX : write IntentSpecificationAttributeValueChangeEvent row
end
IDMS --> GW : 200 OK { intentSpecification }
GW --> Client : 200 OK { intentSpecification }
|||
DISPATCHER -> OUTBOX : poll → deliver AttributeValueChangeEvent to SUB (same as 3a)

== 4 + 5. Activate Draft → "Active" + Auto-Retire Previous ==
note over Client, IDMS : Activation via lifecycle field update only.\nService MUST NOT expose POST .../intentSpecification/{id}/activate
Client -> GW : PUT /intentManagement/v5/intentSpecification/{id} { lifecycleStatus: "Active" }\nor PATCH ... { lifecycleStatus: "Active" }
GW -> IDMS : forward request
group Atomic DB transaction
    IDMS -> CAT : set target spec lifecycleStatus → "Active"
    IDMS -> CAT : find previous Active spec with same familyId → set "Retired"
    IDMS -> OUTBOX : write IntentSpecificationStateChangeEvent { status: Activated }
    IDMS -> OUTBOX : write IntentSpecificationStateChangeEvent { status: Retired, previousSpecId }
end
IDMS --> GW : 200 OK { intentSpecification, lifecycleStatus: "Active" }
GW --> Client : 200 OK { intentSpecification }
|||
DISPATCHER -> OUTBOX : poll → 2 PENDING StateChangeEvents
OUTBOX --> DISPATCHER : [StateChangeEvent(Activated), StateChangeEvent(Retired)]
DISPATCHER -> SUBREG : lookup matching subscriptions
SUBREG --> DISPATCHER : [{ callbackUrl }]
DISPATCHER -> SUB : HTTPS POST {callbackUrl}\n{ event: StateChangeEvent, lifecycleStatus: "Active" }
SUB --> DISPATCHER : 200 OK
DISPATCHER -> SUB : HTTPS POST {callbackUrl}\n{ event: StateChangeEvent, lifecycleStatus: "Retired", id: previousSpecId }
SUB --> DISPATCHER : 200 OK
DISPATCHER -> OUTBOX : mark both events DELIVERED

== 6. Delete Unused Draft IntentSpecification ==
note over Client, IDMS : Allowed only when retention & runtime-reference rules permit
Client -> GW : DELETE /intentManagement/v5/intentSpecification/{id}
GW -> IDMS : forward request
IDMS -> CAT : validate Draft status & no active runtime references
alt deletion permitted
    group Atomic DB transaction
        IDMS -> CAT : remove IntentSpecification
        IDMS -> OUTBOX : write IntentSpecificationDeleteEvent row
    end
    IDMS --> GW : 204 No Content
    GW --> Client : 204 No Content
    |||
    DISPATCHER -> OUTBOX : poll → PENDING DeleteEvent
    OUTBOX --> DISPATCHER : [IntentSpecificationDeleteEvent]
    DISPATCHER -> SUBREG : lookup matching subscriptions
    SUBREG --> DISPATCHER : [{ callbackUrl }]
    DISPATCHER -> SUB : HTTPS POST {callbackUrl}\n{ event: IntentSpecificationDeleteEvent }
    SUB --> DISPATCHER : 200 OK
    DISPATCHER -> OUTBOX : mark DELIVERED
else retention / reference rule violation
    CAT --> IDMS : conflict
    IDMS --> GW : 409 Conflict { reason }
    GW --> Client : 409 Conflict { reason }
end

== 7b. Retrieve External Event Subscription ==
Client -> GW : GET /intentManagement/v5/hub/{id}
GW -> IDMS : forward request
IDMS -> SUBREG : lookup subscription record
SUBREG --> IDMS : subscription
IDMS --> GW : 200 OK { subscription }
GW --> Client : 200 OK { subscription }

== 7c. Delete External Event Subscription ==
Client -> GW : DELETE /intentManagement/v5/hub/{id}
GW -> IDMS : forward request
IDMS -> SUBREG : remove subscription record
SUBREG --> IDMS : confirmed
IDMS --> GW : 204 No Content
GW --> Client : 204 No Content

@enduml