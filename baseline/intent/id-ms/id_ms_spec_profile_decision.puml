@startuml
title IntentSpecification specKey, draftId, and optional metadata profile

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam packageStyle rectangle
skinparam ArrowColor #424242
skinparam RectangleBorderColor #424242

rectangle "TMF921 IntentSpecification\nbase resource model" as TMF #EEF2FF

rectangle "ID MS governed profile\n\nTMF-aligned, not TMF-minimal" as PROFILE #E8F5E9

TMF --> PROFILE : ID MS applies governed\nminimum profile and extensions

rectangle "Create mutable DRAFT candidate" as CREATE #FFF8E1 {
  rectangle "Create request minimum\n\n- specKey\n- name\n- @type\n- @baseType\n\nClient must not send:\n- id\n- draftId\n- official version\n- lifecycleStatus\n- href\n- _links" as CREATE_REQ
  rectangle "Server response\n\n- id resolved from specKey\n- draftId assigned\n- href uses /draft/{draftId}\n- lifecycleStatus = DRAFT\n- ETag returned" as CREATE_RESP
}

rectangle "DRAFT candidate operations" as DRAFT #FFE0B2 {
  rectangle "DRAFT route family\n\nGET /intentSpecification/draft/{draftId}\nPUT /intentSpecification/draft/{draftId}\nPATCH /intentSpecification/draft/{draftId}\nDELETE /intentSpecification/draft/{draftId}" as DRAFT_ROUTES
  rectangle "DRAFT rules\n\n- editable\n- no official public version\n- revision tracked by ETag\n- not valid for runtime admission" as DRAFT_RULES
}

rectangle "Activation gate" as GATE #FFECB3 {
  rectangle "Validate ACTIVE profile\n\n- expressionSpecification\n- expressionSpecification.iri\n- expressionSpecification.expressionLanguage\n- targetEntitySchema\n- specCharacteristic\n- validFor.startDateTime\n\nReject with 422 if incomplete" as VALIDATE
}

rectangle "Official ACTIVE and RETIRED resources" as OFFICIAL #E0F2F1 {
  rectangle "Official route family\n\nGET /intentSpecification/{id}\nDELETE /intentSpecification/{id}\n\nDELETE retires ACTIVE where allowed" as OFFICIAL_ROUTES
  rectangle "Official rules\n\n- ACTIVE and RETIRED are immutable\n- version assigned on activation\n- selected draftId retained as provenance\n- previous ACTIVE for same id is RETIRED" as OFFICIAL_RULES
}

rectangle "Optional classification metadata" as OPTIONAL #F3E5F5 {
  rectangle "intentBehaviour\n\n- category\n- constraintMode\n- objectiveType\n- fulfilmentMode" as BEHAVIOUR
  rectangle "intentLayer\n\nBUSINESS\nSERVICE\nRESOURCE" as LAYER
  rectangle "Classification only\n\nSupports catalogue visibility,\ngovernance visibility, and\nexternal consumer understanding.\n\nNot used by ID MS for runtime\ndecisioning, validation, admission\ncontrol, or behavioural enforcement." as OPTIONAL_RULES
}

rectangle "Runtime Intent admission\nowned by IC MS" as RUNTIME #ECEFF1 {
  rectangle "Runtime admission rule\n\nMust reference a concrete ACTIVE\nintentSpecification.id.\n\nspecKey and draftId must not be used\nfor runtime contract selection." as RUNTIME_RULE
}

PROFILE --> CREATE : create DRAFT candidate
CREATE --> DRAFT : manage by draftId
DRAFT --> GATE : request activation
GATE --> OFFICIAL : ACTIVE profile satisfied
GATE -[#red,dashed]-> DRAFT : required ACTIVE fields missing
OFFICIAL --> RUNTIME : provides active semantic\nand validation contract
PROFILE --> OPTIONAL : may include optional\nclassification metadata

note right of OFFICIAL
specKey represents logical grouping
across specification versions.

If only RETIRED versions exist for a specKey,
ID MS creates a new id by default.
Lineage reuse requires explicit governance
if introduced later.
end note

note bottom of OPTIONAL
CONTINUOUS fulfilmentMode means downstream
systems may operate in a closed-loop manner.
It does not imply mutation of the submitted
runtime Intent instance.
end note



note over IDMS
After activation, GET /intentSpecification/draft/{draftId}
remains a read-only provenance lookup for the
official version produced from that draft.
Runtime admission still uses official ACTIVE id, not draftId.
end note

@enduml
