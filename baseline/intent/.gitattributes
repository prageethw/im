# Intent Platform line-ending and text baseline
* text=auto eol=lf

*.sh text eol=lf
mvnw text eol=lf
*.md text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.puml text eol=lf

*.cmd text eol=crlf
*.bat text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.jar binary
