@startuml
title Intent mandatory profile decision

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam packageStyle rectangle
skinparam ArrowColor #424242
skinparam RectangleBorderColor #424242

rectangle "TMF921 Intent\nbase resource model" as TMF #EEF2FF

rectangle "Intent management entity\nmandatory profile\n\nTMF-aligned, not TMF-minimal" as PROFILE #E8F5E9

TMF --> PROFILE : implementation profile\nfor runtime Intent handling

rectangle "Primary profile:\nruntime Intent admission" as ADMISSION #FFE0B2 {
  rectangle "Minimum admission request\n\n- name\n- intentSpecification.id\n- expression\n- expression.@type\n- expression.iri\n- expression.expressionValue\n- @type\n- @baseType" as ADMISSION_MIN

  rectangle "Strongly encouraged\n\n- humanExpression" as ADMISSION_RECOMMENDED

  rectangle "Both are mandatory\nfor admission\n\nintentSpecification.id selects\nthe platform-managed specification.\n\nexpression.iri identifies\nthe semantic expression contract." as BOTH_REQUIRED

  rectangle "Consistency validation\n\n1. Retrieve ACTIVE IntentSpecification\n   by intentSpecification.id\n2. Compare runtime expression.iri\n   with IntentSpecification.expressionSpecification.iri\n3. Reject if missing or mismatched" as CONSISTENCY
}

rectangle "Persisted Intent response\nafter admission is accepted" as ADMISSION_RESPONSE #E0F2F1 {
  rectangle "Minimum response attributes\n\n- id\n- href\n- name\n- version\n- lifecycleStatus\n- statusReason\n- statusChangeDate\n- intentSpecification.id\n- isBundle\n- expression\n- expression.@type\n- expression.iri\n- expression.expressionValue\n- @type\n- @baseType" as RESPONSE_MIN

  rectangle "Key distinction\n\nintentSpecification.id is mandatory\nin the admission request and\nin the persisted response.\n\nexpression.iri is mandatory\nin the admission request and\npersisted expression." as RESPONSE_DISTINCTION
}

rectangle "Draft \npre-admission authoring context" as DRAFT #FFF8E1 {
  rectangle "Minimum Draft creation request\n\n- name\n- submit = false\n- @type\n- @baseType" as DRAFT_MIN

  rectangle "Strongly recommended\nfor Draft\n\n- humanExpression" as DRAFT_RECOMMENDED

  rectangle "Draft does not require\n\n- intentSpecification.id\n- expression\n- expression.iri\n- expression.expressionValue" as DRAFT_NOT_REQUIRED

  rectangle "Minimum Draft response\n\n- id\n- href\n- name\n- submit = false\n- lifecycleStatus = Draft\n- statusReason\n- statusChangeDate\n- isBundle\n- @type\n- @baseType" as DRAFT_RESPONSE

  rectangle "Draft authoring-record rule\n\nDraft Intents are not assigned\na permanent runtime version.\n\nPermanent runtime version is\nassigned only after admission\nis accepted." as DRAFT_AUTHORING_RECORD_RULE
}

rectangle "Optional intent-management-entity\ngoverned enrichment fields" as ENRICHMENT #F3E5F5 {
  rectangle "Strongly recommended\nbut not generically mandatory\n\n- humanExpression" as ENRICHMENT_RECOMMENDED

  rectangle "Optional and governed\n\n- description\n- validFor.startDateTime\n- isBundle\n- priority\n- relatedParty\n- _links" as ENRICHMENT_OPTIONAL

  rectangle "Rule\n\nMay be required by a specific\nimplementation, product, channel,\npolicy, onboarding profile,\nor security posture.\n\nNot part of the generic\nminimum mandatory profile." as ENRICHMENT_RULE
}

rectangle "Lifecycle ownership guardrail" as GUARDRAIL #E3F2FD {
  rectangle "External consumers must not supply\nlifecycleStatus in any external\nwrite request.\n\ncreate, PUT, PATCH, and other writes" as NO_LIFECYCLE

  rectangle "lifecycleStatus is assigned,\ntransitioned, and projected by\nthe intent management entity." as LIFECYCLE_RULE
}

PROFILE --> ADMISSION : main baseline
ADMISSION --> BOTH_REQUIRED : requires exact resource\nand semantic contract
BOTH_REQUIRED --> CONSISTENCY : validate before admission
CONSISTENCY --> ADMISSION_RESPONSE : admission accepted
PROFILE --> DRAFT : small pre-admission add-on
DRAFT --> ADMISSION : submit=true requires\nnormal admission profile
PROFILE --> ENRICHMENT : separate optional enrichment
PROFILE --> GUARDRAIL : common write rule

note bottom of ADMISSION
Primary paper focus:
runtime Intent admission profile.
Admission requires both
intentSpecification.id and expression.iri.
end note

note bottom of DRAFT
Draft does not replace the
runtime admission profile.
It is only a lighter
pre-admission authoring context.
end note

note bottom of DRAFT_AUTHORING_RECORD_RULE
No draft lineage or special ID
design is part of this decision.
This paper defines minimum
data requirements only.
end note

note bottom of ENRICHMENT
Keep optional enrichment separate
from the generic minimum
mandatory profile.
end note

@enduml
