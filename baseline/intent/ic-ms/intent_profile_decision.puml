@startuml
title Intent mandatory profile proposal

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam packageStyle rectangle
skinparam ArrowColor #424242
skinparam RectangleBorderColor #424242

rectangle "TMF921 Intent\nbase resource model" as TMF #EEF2FF

rectangle "Intent management entity\nmandatory profile\n\nTMF-aligned, not TMF-minimal" as PROFILE #E8F5E9

TMF --> PROFILE : implementation profile\nfor runtime Intent handling

rectangle "Primary profile:\nruntime Intent admission" as ADMISSION #FFE0B2 {
  rectangle "Minimum admission request\n\n- name\n- expression\n- expression.@type\n- expression.iri\n- expression.expressionValue\n- @type\n- @baseType" as ADMISSION_MIN

  rectangle "Strongly encouraged\n\n- humanExpression\n- intentSpecification.id" as ADMISSION_RECOMMENDED

  rectangle "IntentSpecification resolution\n\nintentSpecification.id supplied:\n- authoritative\n- must reference ACTIVE spec\n- must align with expression.iri\n\nintentSpecification.id omitted:\n- resolve ACTIVE spec by expression.iri\n- reject zero or multiple matches" as RESOLUTION
}

rectangle "Persisted Intent response\nafter admission is accepted" as ADMISSION_RESPONSE #E0F2F1 {
  rectangle "Minimum response attributes\n\n- id\n- href\n- name\n- version\n- lifecycleStatus\n- statusReason\n- statusChangeDate\n- intentSpecification.id\n- expression\n- expression.@type\n- expression.iri\n- expression.expressionValue\n- @type\n- @baseType" as RESPONSE_MIN

  rectangle "Key distinction\n\nintentSpecification.id is optional\nin the admission request,\nbut mandatory in the persisted\nresponse after admission." as RESPONSE_DISTINCTION
}

rectangle " Draft \npre-admission authoring context" as DRAFT #FFF8E1 {
  rectangle "Minimum Draft creation request\n\n- name\n- submit = false\n- @type\n- @baseType" as DRAFT_MIN

  rectangle "Strongly recommended\nfor Draft\n\n- humanExpression" as DRAFT_RECOMMENDED

  rectangle "Draft does not require\n\n- expression\n- expression.iri\n- expression.expressionValue\n- intentSpecification.id" as DRAFT_NOT_REQUIRED

  rectangle "Minimum Draft response\n\n- id\n- href\n- name\n- submit = false\n- version\n- lifecycleStatus = Draft\n- statusReason\n- statusChangeDate\n- @type\n- @baseType" as DRAFT_RESPONSE
}

rectangle "Optional intent-management-entity\ngoverned enrichment fields" as ENRICHMENT #F3E5F5 {
  rectangle "Strongly recommended\nbut not generically mandatory\n\n- humanExpression\n- intentSpecification.id\n  in admission request" as ENRICHMENT_RECOMMENDED

  rectangle "Optional / governed\n\n- description\n- validFor.startDateTime\n- isBundle\n- priority\n- relatedParty\n- _links" as ENRICHMENT_OPTIONAL

  rectangle "Rule\n\nMay be required by a specific\nimplementation, product, channel,\npolicy, onboarding profile,\nor security posture.\n\nNot part of the generic\nminimum mandatory profile." as ENRICHMENT_RULE
}

rectangle "Lifecycle ownership guardrail" as GUARDRAIL #E3F2FD {
  rectangle "External consumers must not supply\nlifecycleStatus in any external\nwrite request.\n\ncreate / PUT / PATCH / other writes" as NO_LIFECYCLE

  rectangle "External consumers use submit,\nnot lifecycleStatus, to request\nDraft save or admission.\n\nlifecycleStatus is assigned,\ntransitioned, and projected by\nthe intent management entity." as SUBMIT_RULE
}

PROFILE --> ADMISSION : main baseline
ADMISSION --> RESOLUTION : validate / resolve contract
RESOLUTION --> ADMISSION_RESPONSE : admission accepted
PROFILE --> DRAFT : small pre-admission add-on
DRAFT --> ADMISSION : submit=true requires\nnormal admission profile
PROFILE --> ENRICHMENT : separate optional enrichment
PROFILE --> GUARDRAIL : common write rule

note bottom of ADMISSION
Primary paper focus:
runtime Intent admission profile.
end note

note bottom of DRAFT
Draft does not replace the
runtime admission profile.
It is only a lighter
pre-admission authoring context.
end note

note bottom of ENRICHMENT
Keep optional enrichment separate
from the generic minimum
mandatory profile.
end note

@enduml
