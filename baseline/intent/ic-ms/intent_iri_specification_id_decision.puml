@startuml
title Runtime Intent contract reference decision: IRI, IntentSpecification ID, or both

skinparam shadowing false
skinparam defaultTextAlignment center
skinparam packageStyle rectangle
skinparam ArrowColor #424242
skinparam RectangleBorderColor #424242

rectangle "Runtime Intent\nadmission request" as INTENT #EEF2FF

rectangle "Decision question" as QUESTION #FFF3E0 {
  rectangle "Should admission require:\n\n1. expression.iri only\n2. intentSpecification.id only\n3. both fields" as Q
}

rectangle "Option 1:\nexpression.iri only" as IRI_ONLY #FFEBEE {
  rectangle "Meaning\n\nExpression declares semantic /\nexpression contract." as IRI_MEANING
  rectangle "Problem\n\nSame IRI can be referenced by\nmultiple ACTIVE IntentSpecifications.\n\nAdmission becomes ambiguous." as IRI_PROBLEM
  rectangle "Decision\n\nRejected" as IRI_REJECTED
}

rectangle "Option 2:\nintentSpecification.id only" as ID_ONLY #FFEBEE {
  rectangle "Meaning\n\nRequest selects exact\nplatform-managed specification." as ID_MEANING
  rectangle "Problem\n\nRuntime expression no longer\nself-declares semantic contract.\n\nNo IRI consistency check." as ID_PROBLEM
  rectangle "Decision\n\nRejected" as ID_REJECTED
}

rectangle "Option 3:\nRequire both" as BOTH #E8F5E9 {
  rectangle "intentSpecification.id\n\nSelects exact ACTIVE\nplatform-managed specification\nfor validation, governance,\nlifecycle and audit." as BOTH_ID

  rectangle "expression.iri\n\nIdentifies semantic /\nexpression contract claimed\nby the runtime expression." as BOTH_IRI

  rectangle "Consistency check\n\nIntent.expression.iri must match\nIntentSpecification.expressionSpecification.iri." as BOTH_CHECK

  rectangle "Decision\n\nAccepted baseline" as BOTH_ACCEPTED
}

rectangle "Admission validation" as VALIDATION #E3F2FD {
  rectangle "1. Require intentSpecification.id\n2. Retrieve referenced specification\n3. Verify lifecycleStatus = ACTIVE\n4. Require expression.iri\n5. Compare with expressionSpecification.iri\n6. Reject missing or mismatched values" as VALIDATION_STEPS
}

rectangle "Draft handling" as DRAFT #FFF8E1 {
  rectangle "Draft creation is lighter\n\nDraft does not require:\n- intentSpecification.id\n- expression.iri\n\nBoth become mandatory\nonly when admission is requested." as DRAFT_RULE
}

rectangle "Outcome" as OUTCOME #E0F2F1 {
  rectangle "Runtime admission requires both:\n\n- intentSpecification.id\n- expression.iri\n\nNo admission by IRI alone." as OUTCOME_RULE
}

INTENT --> QUESTION
QUESTION --> IRI_ONLY
QUESTION --> ID_ONLY
QUESTION --> BOTH

IRI_ONLY -[#red,dashed]-> BOTH : ambiguity risk
ID_ONLY -[#red,dashed]-> BOTH : loses semantic self-description
BOTH --> VALIDATION
VALIDATION --> OUTCOME
DRAFT --> VALIDATION : submit=true

note bottom of BOTH
The fields serve different purposes.
One identifies the platform resource.
The other identifies the semantic contract.
end note

note bottom of OUTCOME
This is stricter than TMF-minimal,
but safer for runtime governance and audit.
end note

@enduml
