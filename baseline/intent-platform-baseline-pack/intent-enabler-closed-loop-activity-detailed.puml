@startuml
title Intent Enabler — Closed-Loop Activity Flow

' ---------- Styling ----------
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 14
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #475569
  FontColor #111827
  DiamondBackgroundColor #FFFFFF
  DiamondBorderColor #64748B
  ArrowColor #374151
  StartColor #22C55E
  EndColor #111827
}
skinparam partition {
  BorderColor #CBD5E1
  FontColor #111827
  FontStyle bold
}
skinparam note {
  BackgroundColor #FFF7D6
  BorderColor #D97706
  FontColor #111827
}
skinparam maxMessageSize 90

start

partition "Intent Consumer" #BAE6FD {
  :Client / OEX submits Intent;
}

partition "Intent Domain — IC MS" #BBF7D0 {
  :Receive Intent request;
  :Validate syntax against active IntentSpecification;
}

if (Syntactic validation passed?) then (Yes)
  partition "Intent Domain — IC MS" #BBF7D0 {
    :Admit request;
    :Set lifecycleStatus = Acknowledged;
    :Emit IntentValidatedEvent;
  }
else (No)
  partition "Intent Domain — IC MS" #BBF7D0 {
    :Reject request;
    :Project external Intent / IntentReport;
  }
  stop
endif

partition "Intent Domain — II MS" #BBF7D0 {
  :Consume IntentValidatedEvent;
  :Semantic validation and resolution;
  note right
    Includes:
    - interpret meaning
    - evaluate policy
    - discover candidates
    - prepare optimisation decision
  end note
}

if (Semantic validation / resolution passed?) then (Yes)
else (No)
  partition "Intent Domain — II MS" #BBF7D0 {
    :Emit IntentRejectedEvent;
  }
  partition "Intent Domain — IC MS" #BBF7D0 {
    :Update external Intent lifecycleStatus = Rejected;
    :Update IntentReport;
  }
  stop
endif

if (Optimisation required?) then (Yes)
  partition "Intent Domain — II MS" #BBF7D0 {
    :Emit IntentResolvedEvent;
  }

  partition "Other T7 Entities — t7.optimiser" #DDD6FE {
    :Consume IntentResolvedEvent;
    :Optimise applicable resources;
    :Emit IntentOptimisedEvent;
  }

  partition "Intent Domain — II MS" #BBF7D0 {
    :Consume IntentOptimisedEvent;
    :Build network-ready package;
    :Emit IntentNetworkReadyEvent;
  }
else (No)
  partition "Intent Domain — II MS" #BBF7D0 {
    :Build network-ready package directly;
    :Emit IntentNetworkReadyEvent;
  }
endif

partition "Intent Domain — IA MS" #BBF7D0 {
  :Consume IntentNetworkReadyEvent;
  :Subscribe to t7.telemetry;
}

partition "Other T7 Entities — t7.telemetry" #DDD6FE {
  :Accept telemetry subscription for intended configuration / resource context;
}

partition "Other T7 Entities — t7.orchestrator" #DDD6FE {
  :Receive apply configuration request;
  :Apply configuration;
  :Return apply result;
}

partition "Intent Support Domain — ICB MS" #FDE68A {
  :Receive network state callback via gateway;
  :POST /intent/callback/v1/submissions;
  :Publish / mediate network state into internal event path;
}

partition "Intent Domain — IA MS" #BBF7D0 {
  :Consume mediated network state;
}

if (Apply accepted / active?) then (Yes)
  partition "Intent Domain — IA MS" #BBF7D0 {
    :Start runtime assurance / control loop;
    :Emit IntentAssuranceEvent lifecycleStatus = Active;
  }

  partition "Intent Domain — IC MS" #BBF7D0 {
    :Update external Intent;
    :Update IntentReport;
  }
else (No)
  partition "Intent Domain — IA MS" #BBF7D0 {
    :Emit IntentAssuranceEvent lifecycleStatus = Failed or Rejected;
  }

  partition "Intent Domain — IC MS" #BBF7D0 {
    :Update external Intent;
    :Update IntentReport;
  }
  stop
endif

while (Intent still active?) is (Yes)

  partition "Other T7 Entities — t7.telemetry" #DDD6FE {
    :Stream real-time telemetry;
  }

  partition "Intent Domain — IA MS" #BBF7D0 {
    :Evaluate runtime state;
    :Assess active resources, evaluations and metrics;
  }

  if (Status/lifecycle change detected?) then (Yes)

    if (Degraded status change?) then (Yes)
      partition "Intent Domain — IA MS" #BBF7D0 {
        :Emit IntentAssuranceEvent Degraded with candidates;
        note right
          candidates are conditional.
          When present, candidates include
          the current active resources too.
        end note
      }

      partition "Intent Domain — IC MS" #BBF7D0 {
        :Update external Intent;
        :Update IntentReport;
      }

      partition "Intent Domain — II MS" #BBF7D0 {
        :Consume IntentAssuranceEvent;
        :Evaluate re-decision need using knowledge and candidates;
        :Emit IntentResolvedEvent;
      }

      partition "Other T7 Entities — t7.optimiser" #DDD6FE {
        :Consume IntentResolvedEvent;
        :Re-optimise applicable resources;
        :Emit IntentOptimisedEvent;
      }

      partition "Intent Domain — II MS" #BBF7D0 {
        :Consume IntentOptimisedEvent;
        :Emit IntentNetworkReadyEvent;
      }

      partition "Intent Domain — IA MS" #BBF7D0 {
        :Consume IntentNetworkReadyEvent;
        :Prepare / refresh telemetry subscription for updated configuration;
      }

      partition "Other T7 Entities — t7.telemetry" #DDD6FE {
        :Refresh telemetry subscription for updated configuration;
      }

      partition "Other T7 Entities — t7.orchestrator" #DDD6FE {
        :Apply updated configuration;
        :Return apply result;
      }

      partition "Intent Support Domain — ICB MS" #FDE68A {
        :Receive network state callback via gateway;
        :POST /intent/callback/v1/submissions;
        :Publish / mediate network state into internal event path;
      }

      partition "Intent Domain — IA MS" #BBF7D0 {
        :Consume mediated network state;
      }

    else (Non-degraded)
      partition "Intent Domain — IA MS" #BBF7D0 {
        :Emit IntentAssuranceEvent non-degraded form;
      }

      partition "Intent Domain — IC MS" #BBF7D0 {
        :Update external Intent;
        :Update IntentReport;
      }
    endif

  else (No)
    partition "Intent Domain — IA MS" #BBF7D0 {
      :Keep current configuration in service;
      :Continue monitoring;
    }
  endif

endwhile (No)

partition "Intent Domain — IC MS" #BBF7D0 {
  :Project final external lifecycle state;
}

stop

legend bottom
|= Colour |= Domain |
|<#BAE6FD> Intent Consumer | Client / OEX and entry path |
|<#BBF7D0> Intent Domain | ID MS, IC MS, II MS, IA MS |
|<#FDE68A> Intent Support Domain | ICB MS incoming callback mediation |
|<#DDD6FE> Other T7 Entities | t7.optimiser, t7.orchestrator, t7.telemetry |
endlegend

@enduml
