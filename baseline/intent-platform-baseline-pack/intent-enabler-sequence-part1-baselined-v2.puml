@startuml
title Intent Enabler — Sequence Part 1: Definition to Initial Assurance

' ---------- Styling ----------
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 14
skinparam sequence {
  ArrowThickness 2
  LifeLineBorderColor #64748B
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
  ParticipantBackgroundColor #FFFFFF
  ParticipantFontColor #111827
  ParticipantFontStyle bold
  ActorBorderColor #334155
  ActorBackgroundColor #FFFFFF
  ActorFontColor #111827
  DividerBackgroundColor #E0E7FF
  DividerBorderColor #64748B
  DividerFontColor #111827
  DividerFontStyle bold
  GroupBorderColor #64748B
  GroupBackgroundColor #F8FAFC
  NoteBackgroundColor #FEF3C7
  NoteBorderColor #D97706
  NoteFontColor #111827
}
skinparam maxMessageSize 90
skinparam ParticipantPadding 20
skinparam BoxPadding 16
autonumber "<b>[000]"


box "Intent Consumer" #BAE6FD
actor "Client\n(OEX)" as Client
participant "Gateway" as GW
end box

box "Intent Domain" #BBF7D0
participant "ID MS\nintent-definition-ms" as ID
participant "IC MS\nintent-controller-ms" as IC
participant "II MS\nintent-intelligence-ms" as II
participant "IA MS\nintent-assurance-ms" as IA
end box

box "Intent Support Domain" #FDE68A
participant "ICB MS\nintent-callback-ms" as ICB
end box

box "Other T7 Entities" #DDD6FE
participant "t7.optimiser" as OPT
participant "t7.orchestrator" as ORCH
participant "t7.telemetry" as TEL
end box


== 1. IntentSpecification definition ==

Client -[#111827]> GW: POST /intentManagement/v5/intentSpecification
GW -[#111827]> ID: Forward create IntentSpecification request
activate ID
ID -[#64748B]> ID: Validate structure, version\nlifecycle and governance rules
ID -[#111827]--> GW: 201 Created\nIntentSpecification
deactivate ID
GW -[#111827]--> Client: IntentSpecification response

opt Specification governance / activation
  Client -[#111827]> GW: PUT /intentManagement/v5/intentSpecification/{id}\nor governance activation action
  GW -[#111827]> ID: Forward update / activation request
  activate ID
  ID -[#64748B]> ID: Apply governance rules\nDRAFT -> ACTIVE\nprevious ACTIVE -> RETIRED
  ID -[#111827]--> GW: Updated IntentSpecification response
  deactivate ID
  GW -[#111827]--> Client: Updated specification response
end

== 2. Intent creation and syntactic validation ==

Client -[#111827]> GW: POST /intentManagement/v5/intent
GW -[#111827]> IC: Forward create Intent request
activate IC
IC -[#111827]> ID: Validate against active IntentSpecification
activate ID
ID -[#111827]--> IC: Validation result
deactivate ID

alt Syntactic validation fails
  IC -[#DC2626]> IC: <color:#DC2626><b>Set lifecycleStatus = Rejected</b></color>
  IC -[#DC2626]--> GW: <color:#DC2626><b>Error / rejected Intent representation</b></color>
  deactivate IC
  GW -[#DC2626]--> Client: <color:#DC2626><b>Rejection response</b></color>
else Syntactic validation succeeds
  IC -[#64748B]> IC: Admit request\nlifecycleStatus = Acknowledged
  IC -[#1D4ED8]> II: <color:#1D4ED8><b>IntentValidatedEvent</b></color>
  deactivate IC
end

== 3. II MS semantic validation and resolution ==

activate II
II -[#64748B]> II: Semantic validation and resolution\n- interpret meaning\n- evaluate policy\n- discover candidates\n- prepare optimisation decision

alt Semantic validation / resolution fails
  II -[#DC2626]> IC: <color:#DC2626><b>IntentRejectedEvent</b></color>
  activate IC
  IC -[#DC2626]> IC: Project external Intent\nlifecycleStatus = Rejected
  IC -[#DC2626]--> GW: External state/report available
  deactivate IC
  deactivate II
else Semantic validation / resolution succeeds
  II -[#64748B]> II: Decide whether optimisation is required
end

== 4. Optimisation and network-ready handoff ==

alt Optimisation required
  II -[#15803D]> OPT: <color:#15803D><b>IntentResolvedEvent</b></color>
  activate OPT
  OPT -[#15803D]> OPT: Optimise selected resources
  OPT -[#15803D]--> II: <color:#15803D><b>IntentOptimisedEvent</b></color>
  deactivate OPT
  II -[#1D4ED8]> IA: <color:#1D4ED8><b>IntentNetworkReadyEvent</b></color>
else Optimisation not required
  II -[#1D4ED8]> IA: <color:#1D4ED8><b>IntentNetworkReadyEvent</b></color>
end
deactivate II

== 5. Subscribe telemetry, apply configuration and start runtime assurance ==

activate IA

IA -[#7C3AED]> TEL: <color:#7C3AED><b>Subscribe to telemetry</b></color>\nfor intended configuration / resource context
activate TEL
TEL -[#7C3AED]--> IA: <color:#7C3AED><b>Subscription acknowledged</b></color>
deactivate TEL

IA -[#7C3AED]> ORCH: <color:#7C3AED><b>Apply configuration</b></color>
activate ORCH
ORCH -[#7C3AED]--> IA: <color:#7C3AED><b>Apply result</b></color>
deactivate ORCH

ORCH -[#7C3AED]> GW: <color:#7C3AED><b>Network state callback</b></color>
GW -[#7C3AED]> ICB: <color:#7C3AED><b>POST /intent/callback/v1/submissions</b></color>
activate ICB
ICB -[#7C3AED]> IA: <color:#7C3AED><b>Publish / mediate network state</b></color>\ninto internal event path
deactivate ICB

alt Apply rejected or failed
  IA -[#EA580C]> IC: <color:#EA580C><b>IntentAssuranceEvent</b></color>\nlifecycleStatus = Failed or Rejected
  activate IC
  IC -[#EA580C]> IC: Update external Intent\nand IntentReport
  deactivate IC
else Apply accepted / active
  IA -[#64748B]> IA: Start runtime assurance / control loop\nusing real-time telemetry
  IA -[#EA580C]> IC: <color:#EA580C><b>IntentAssuranceEvent</b></color>\nlifecycleStatus = Active
  activate IC
  IC -[#EA580C]> IC: Update external Intent\nand IntentReport
  deactivate IC
end
deactivate IA


legend bottom
|= Visual cue |= Meaning |
|<#BAE6FD> Intent Consumer | Client and gateway entry path |
|<#BBF7D0> Intent Domain | Core intent microservices |
|<#FDE68A> Intent Support Domain | ICB MS incoming callback mediation |
|<#DDD6FE> Other T7 Entities | t7.optimiser, t7.orchestrator and t7.telemetry |
|<#DBEAFE> <color:#1D4ED8><b>Blue event labels</b></color> | Internal intent events |
|<#DCFCE7> <color:#15803D><b>Green event labels</b></color> | Optimisation events |
|<#FED7AA> <color:#EA580C><b>Orange event labels</b></color> | Assurance / lifecycle events |
|<#EDE9FE> <color:#7C3AED><b>Purple event labels</b></color> | Network callback / orchestrator path |
|<#FECACA> <color:#DC2626><b>Red event labels</b></color> | Rejection / failure path |
endlegend

@enduml
