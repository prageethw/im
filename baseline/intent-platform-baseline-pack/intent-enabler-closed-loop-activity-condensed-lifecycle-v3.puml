@startuml
title Intent Enabler — Condensed Closed-Loop Activity Flow

' ---------- Styling ----------
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 14
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #475569
  FontColor #111827
  DiamondBackgroundColor #FFFFFF
  DiamondBorderColor #64748B
  ArrowColor #374151
  StartColor #22C55E
  EndColor #111827
}
skinparam partition {
  BorderColor #CBD5E1
  FontColor #111827
  FontStyle bold
}
skinparam note {
  BackgroundColor #FFF7D6
  BorderColor #D97706
  FontColor #111827
}
skinparam maxMessageSize 80

start

note right
  Main lifecycle progression:
  Acknowledged -> InProgress -> Active
  Active -> Degraded -> InProgress -> Active
  or Rejected / Failed / Paused / Terminated
end note

partition "Intent Consumer" #BAE6FD {
  :Submit Intent;
}

partition "Intent Domain" #BBF7D0 {
  :IC MS validates syntax against active IntentSpecification;
  :Admit Intent\nlifecycleStatus = Acknowledged;
}

if (Syntax valid?) then (Yes)
else (No)
  partition "Intent Domain" #BBF7D0 {
    :Reject Intent;
    :Project lifecycleStatus = Rejected;
    :Project external Intent / IntentReport;
  }
  stop
endif

partition "Intent Domain" #BBF7D0 {
  :II MS performs semantic validation and resolution;
  :Workflow processing\nlifecycleStatus = InProgress;
  note right
    Interpret meaning, evaluate policy,
    discover candidates and prepare
    optimisation decision.
  end note
}

if (Semantic validation passed?) then (Yes)
else (No)
  partition "Intent Domain" #BBF7D0 {
    :Emit rejection;
    :Project lifecycleStatus = Rejected;
    :Project external Intent / IntentReport;
  }
  stop
endif

if (Optimisation required?) then (Yes)
  partition "Other T7 Entities" #DDD6FE {
    :t7.optimiser optimises resources;
  }
else (No)
endif

partition "Intent Domain" #BBF7D0 {
  :II MS emits network-ready handoff;
}

partition "Intent Domain" #BBF7D0 {
  :IA MS subscribes to t7.telemetry;
}

partition "Other T7 Entities" #DDD6FE {
  :t7.orchestrator applies configuration;
}

partition "Intent Support Domain" #FDE68A {
  :ICB MS mediates network callback;
}

partition "Intent Domain" #BBF7D0 {
  :IA MS starts assurance loop;
  :Emit IntentAssuranceEvent\nlifecycleStatus = Active / Failed;
}

if (Apply active?) then (Yes)
else (No)
  partition "Intent Domain" #BBF7D0 {
    :IC MS updates external Intent / IntentReport;
  }
  stop
endif

while (Intent still active?) is (Yes)

  partition "Other T7 Entities" #DDD6FE {
    :t7.telemetry streams real-time metrics;
  }

  partition "Intent Domain" #BBF7D0 {
    :IA MS evaluates runtime assurance state;
  }

  if (Status/lifecycle changed?) then (Yes)
    if (Degraded?) then (Yes)
      partition "Intent Domain" #BBF7D0 {
        :IA MS emits degraded IntentAssuranceEvent with candidates;
        :Project lifecycleStatus = Degraded;
        :IC MS updates external Intent / IntentReport;
        :II MS evaluates re-decision;
        :Re-decision processing\nlifecycleStatus = InProgress;
      }

      partition "Other T7 Entities" #DDD6FE {
        :t7.optimiser re-optimises resources;
      }

      partition "Intent Domain" #BBF7D0 {
        :II MS emits updated network-ready handoff;
        :IA MS refreshes telemetry subscription;
      }

      partition "Other T7 Entities" #DDD6FE {
        :t7.orchestrator applies updated configuration;
      }

      partition "Intent Support Domain" #FDE68A {
        :ICB MS mediates updated network callback;
      }

    else (Non-degraded)
      partition "Intent Domain" #BBF7D0 {
        :IA MS emits non-degraded IntentAssuranceEvent;
        :Project lifecycleStatus = Active;
        :IC MS updates external Intent / IntentReport;
      }
    endif
  else (No)
    partition "Intent Domain" #BBF7D0 {
      :Keep current configuration in service;
      :Continue monitoring;
    }
  endif

endwhile (No)

partition "Intent Domain" #BBF7D0 {
  :Project final external lifecycle state\nPaused / Failed / Terminated as applicable;
}

stop

legend bottom
|= Colour |= Domain |
|<#BAE6FD> Intent Consumer | Client / OEX |
|<#BBF7D0> Intent Domain | ID MS, IC MS, II MS, IA MS |
|<#FDE68A> Intent Support Domain | ICB MS |
|<#DDD6FE> Other T7 Entities | t7.optimiser, t7.orchestrator, t7.telemetry |
endlegend

@enduml
